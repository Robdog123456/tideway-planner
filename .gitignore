# Personal / local-only data — NEVER committed (public repo).
# Raw Strava GPS, outing manifest, per-pass derivations, historical PLA pulls,
# and the PLA Tideway Code copy all live here; the backtest reads them via the
# pipeline/raw and pipeline/passes.csv symlinks below.
local-data/

# Symlinks into local-data (unchanged-code shims for the model scripts)
pipeline/raw
pipeline/passes.csv

# Live wind is refetched fresh every pipeline run (no cache value — a failed
# fetch fails the run and the last published grid stays live), so its ~1 MB
# per cycle never enters git history. Tides + flag.json ARE committed: tides
# are the month-long resilience cache, flag.json is the keep-previous fallback.
pipeline/data/wind/

# Python / editor noise
__pycache__/
*.pyc
.venv/
.DS_Store
pipeline/grid_v2.json
